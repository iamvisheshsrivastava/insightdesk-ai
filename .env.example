# API runtime
PYTHONUNBUFFERED=1
PYTHONPATH=/app

# Neo4j / Graph-RAG (local development)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Cloud Deployment - Neo4j Aura (https://neo4j.com/cloud/aura/)
# NEO4J_URI=bolt://xxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-aura-password
# NEO4J_DATABASE=neo4j

# AWS S3 - For storing models and FAISS vectors
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_BUCKET_NAME=insightdesk-models
# AWS_REGION=us-east-1

# Optional: LLM/LangChain API keys (if you add LLM features)
# OPENAI_API_KEY=your-key
# ANTHROPIC_API_KEY=your-key
# HUGGINGFACE_API_KEY=your-key

# MLflow tracking (optional)
# MLFLOW_TRACKING_URI=http://localhost:5000

# Frontend URL (set in Vercel/Fly.io)
# VITE_API_URL=https://insightdesk-api.fly.dev
